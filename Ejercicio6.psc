Algoritmo Piramide
	
	Definir altura, espacio, fila, num como entero
	
	Escribir "Ingrese la altura de la piramide"
	Leer altura
	
	Para fila <- 1 hasta altura Hacer
		para espacio <- 1 hasta altura - fila hacer
			Escribir " " sin saltar
		FinPara
		
		para num <- 1 hasta fila Hacer
			Escribir num sin saltar
		FinPara
		
		Escribir ""
	FinPara
	
FinAlgoritmo
